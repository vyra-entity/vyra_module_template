<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="42">
    <General>
      <!-- Disable multicast (not supported reliably in Docker Swarm overlay networks) -->
      <AllowMulticast>false</AllowMulticast>

      <!-- Fragment size for large messages -->
      <FragmentSize>4kB</FragmentSize>

      <!-- Maximum message size -->
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <!-- Participant index for unique identification -->
      <ParticipantIndex>auto</ParticipantIndex>
    </Discovery>

    <Tracing>
      <!-- Logging configuration:
           none, severe, error, warning, info, config, fine, finer, finest
      -->
      <Verbosity>warning</Verbosity>
      <OutputFile>stdout</OutputFile>
    </Tracing>

    <!-- Internal configuration for performance tuning -->
    <Internal>
      <!-- Heartbeat and response timing -->
      <Watermarks>
        <WhcHigh>500kB</WhcHigh>
      </Watermarks>
    </Internal>

  </Domain>
</CycloneDDS>
